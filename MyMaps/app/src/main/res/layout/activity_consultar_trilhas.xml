<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#453E3E"
    android:padding="16dp">

    <TextView
        android:id="@+id/txt_titulo_historico"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Histórico de Trilhas"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/container_botoes_limpeza"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txt_titulo_historico">

        <Button
            android:id="@+id/btn_limpar_intervalo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#448C84"
            android:text="Apagar por Data"
            android:textColor="@color/white"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_limpar_tudo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="#FF3B30"
            android:text="Apagar Tudo"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <ListView
        android:id="@+id/list_view_trilhas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:divider="#66FFFFFF"
        android:dividerHeight="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/container_botoes_limpeza" />

</androidx.constraintlayout.widget.ConstraintLayout>